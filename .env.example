# ===== RD-Agent(Q) 本地运行配置 — 复制为 .env 并填入你的 key =====
# bootstrap.sh 会自动生成 .env（含正确的本机绝对路径），一般无需手动改。
# 手动配置时，注意把 <YOUR_HOME> 换成 `echo $HOME` 的输出。

BACKEND=rdagent.oai.backend.LiteLLMAPIBackend

# ---- 对话模型：DeepSeek（OpenAI 兼容，经 LiteLLM）----
CHAT_MODEL=deepseek/deepseek-chat
DEEPSEEK_API_KEY=sk-REPLACE_WITH_YOUR_DEEPSEEK_KEY
# DeepSeek 不支持 response_schema，必须关掉
ENABLE_RESPONSE_SCHEMA=False

# ---- Embedding：本地 Ollama（DeepSeek 无 embedding 接口，用本地零成本方案）----
EMBEDDING_MODEL=ollama/nomic-embed-text
OLLAMA_API_BASE=http://localhost:11434

# ---- 因子代码执行用的 Python（必须是绝对路径，指向装了 pandas 的 rdagent 环境）----
# bootstrap.sh 会写成 $HOME/miniconda3/envs/rdagent/bin/python
FACTOR_CoSTEER_PYTHON_BIN=<YOUR_HOME>/miniconda3/envs/rdagent/bin/python

# ---- 回测执行后端：conda（用 rdagent4qlib 环境跑 qrun，无需 Docker）----
MODEL_CoSTEER_ENV_TYPE=conda

# ---- 控制重试/成本 ----
MAX_RETRY=5
RETRY_WAIT_SECONDS=10
